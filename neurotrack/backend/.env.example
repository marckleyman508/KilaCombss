NODE_ENV=development
PORT=4000

# ── PostgreSQL ────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:password@localhost:5432/neurotrack

# ── JWT ───────────────────────────────────────────────────────────────────────
# Generate: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=change_this_to_a_long_random_secret_minimum_64_chars
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_DAYS=7

# ── HIPAA: Audit log patient ID hashing (HMAC-SHA256 pepper) ─────────────────
# REQUIRED in production. Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Never rotate this key after go-live without rehashing existing audit records.
AUDIT_PEPPER=change_this_to_a_64_char_random_hex_string

# ── HIPAA: Field-level PHI encryption (AES-256-GCM) ──────────────────────────
# REQUIRED in production. Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Store in AWS KMS / Secrets Manager. 64 hex chars = 256-bit key.
FIELD_ENCRYPTION_KEY=change_this_to_a_64_char_random_hex_string_exactly

# ── CORS ──────────────────────────────────────────────────────────────────────
# No trailing slash. Must match your frontend origin exactly.
FRONTEND_URL=http://localhost:5173
